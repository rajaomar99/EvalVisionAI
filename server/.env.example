NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=your_mongodb_uri_here

# Session
# Generate a new one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_session_secret_here

# Google OAuth
# Get these from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Client URL
CLIENT_ORIGIN=http://localhost:5173

# AI Microservice
AI_SERVICE_URL=http://localhost:8001

# UploadThing token
# Get this from: https://uploadthing.com/
UPLOADTHING_TOKEN=your_uploadthing_token_here

# AI API key (must match API_KEY in ai-service/.env)
AI_API_KEY=your_secret_api_key_here
